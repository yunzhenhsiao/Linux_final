# TransitFlow Development Environment Configuration
LLM_PROVIDER=ollama
LOG_LEVEL=DEBUG

# Ollama settings (Local container)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3.2:1b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=300

# PostgreSQL (Docker container internal network)
PG_HOST=postgres
PG_PORT=5432
PG_USER=transitflow
PG_PASSWORD=transitflow
PG_DB=transitflow

# Neo4j (Docker container internal network)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=transitflow

# Redis (Docker container internal network)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Database Initialization
AUTO_INIT_DB=yes

# Limits & Backups
RATE_LIMIT_S=0
DB_BACKUP_SCHEDULE=none

# RAG / Vector tuning
VECTOR_TOP_K=3
VECTOR_SIMILARITY_THRESHOLD=0.5
EMPLOYEE_KEY=emp_secret_2024
ADMIN_KEY=admin_master_2024
